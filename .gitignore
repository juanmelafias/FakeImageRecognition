# .gitignore for AI Image Detection & Face Recognition Projects

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints
*.ipynb

# PyTorch models and checkpoints
*.pth
*.pt
*.ckpt

# Data files
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
# FaceRecognition specific data
FaceRecognition/data/raw/lfw/*
FaceRecognition/data/raw/*.tgz
FaceRecognition/data/raw/*.tar.gz
FaceRecognition/data/processed/*

# Models (except .gitkeep)
models/*
!models/.gitkeep
FaceRecognition/models/*.pth
!FaceRecognition/models/.gitkeep

# TensorBoard
runs/
logs/*
!logs/.gitkeep
FaceRecognition/logs/*
!FaceRecognition/logs/.gitkeep
events.out.tfevents.*

# Results
results/*
!results/.gitkeep
FaceRecognition/results/*
!FaceRecognition/results/.gitkeep
*.png
*.jpg
*.jpeg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Mac
.DS_Store

# Kaggle credentials
.kaggle/
kaggle.json

# Environment variables
.env

# Text files
*.txt
