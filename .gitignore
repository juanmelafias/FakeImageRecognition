# .gitignore for AI Image Detection Project

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# PyTorch
*.pth
*.pt
*.ckpt

# Data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Models (except .gitkeep)
models/*
!models/.gitkeep

# TensorBoard
runs/
logs/

# Results
results/
*.png
*.jpg
*.jpeg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Mac
.DS_Store

# Kaggle credentials
.kaggle/
kaggle.json

# Environment variables
.env
